<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ContactUs Login Dashboard</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <div class="form-container">
        <h2>Contact Us</h2>
        <form action="/login" method="post">

            <div class="form-group">
                <label for="name">Name:-</label>
                <input type="text" id="name" name="username" placeholder="Enter your name" required autocomplete="off">
            </div>
            <div class="form-group">
                <label for="email">Email:-</label>
                <input type="email" name="email" id="emailaddress" placeholder="Enter Your Email" required>
            </div>
            <div class="form-group">
                <label for="mobile number">Mobile Number:-</label>
                <input type="10 digit mobile number" id="number" name="10 digit mobile number"
                    placeholder="Enter your Mobile Number" required autocomplete="off">
            </div>

            <h2>Select Location</h2>
            <label for="country">Country:</label>
            <select id="country" name="country">
                <option value="">Select Country</option>
                <option value="usa">United States</option>
                <option value="canada">Canada</option>
                <option value="india">India</option>
                <option value="australia">Australia</option>
            </select>
            <br><br>

            <label for="state">State:</label>
            <select id="state" name="state">
                <option value="">Select State</option>
                <option value="Wasington_DC">Wasington DC</option>
                <option value="Ottawa">Ottawa</option>
                <option value="New_Delhi">New Delhi</option>
                <option value="Canberra">Canberra</option>
                <option value="Tamil_Nadu">Tamil Nadu</option>
                <option value="Uttar_Pradesh">Uttar Pradesh</option>
            </select>
            <br><br>

            <label for="location">Location:</label>
            <select id="location" name="location">
                <option value="">Select Location</option>
                <option value="home_address">Home Address</option>
                <option value="business_address">Business Address</option>
                <option value="billing_address">Billing Address</option>
                <option value="shipping_address">Shipping Address</option>
                <option value="office_address">Office Address</option>
                <option value="college_address">College Address</option>
            </select>

            <button type="submit" class="submit-btn">Submit</button>
        </form>
        <p>Don't have an account? <a href="/signup">Signup</a></p>

    </div>
</body>
</html>